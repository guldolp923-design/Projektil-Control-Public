{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PROJEKTIL Control",
  "version": "1.0.10-beta",
  "identifier": "com.projektil.control",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "PROJEKTIL Control",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true,
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/icon_32.png",
      "icons/icon.png",
      "icons/icon_256.png"
    ]
  }
}
